{"texts":{"content_text0":"\u039c\u03b1\u03bd\u03c4\u03ad\u03c8\u03c4\u03b5","content_text1":"\u03a0\u03c1\u03b9\u03bd \u03be\u03b5\u03ba\u03b9\u03bd\u03ae\u03c3\u03b5\u03c4\u03b5 \u03c4\u03bf \u03bc\u03ac\u03b8\u03b7\u03bc\u03b1, \u03b1\u03c2 \u03b6\u03b5\u03c3\u03c4\u03b1\u03b8\u03bf\u03cd\u03bc\u03b5 \u03ba\u03b1\u03b9 \u03b1\u03c2 \u03bc\u03b1\u03bd\u03c4\u03ad\u03c8\u03bf\u03c5\u03bc\u03b5:","content_text100":"\u0388\u03bd\u03b1\u03c2 \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf\u03c2 \u03c7\u03ac\u03bd\u03b5\u03b9 \u03cc\u03bb\u03b1 \u03c4\u03b1 \u03b4\u03b9\u03ba\u03b1\u03b9\u03ce\u03bc\u03b1\u03c4\u03ac \u03c4\u03bf\u03c5 \u03bc\u03cc\u03bb\u03b9\u03c2 \u03c6\u03c5\u03bb\u03b1\u03ba\u03b9\u03c3\u03c4\u03b5\u03af","content_text200_0":"\u0391\u039b\u0397\u0398\u0395\u03a3","content_text200_1":"\u03a8\u0395\u03a5\u0394\u0395\u03a3","content_text300":"\u039f\u03b9 \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf\u03b9 \u03c7\u03ac\u03bd\u03bf\u03c5\u03bd \u03c4\u03b7\u03bd \u03b5\u03bb\u03b5\u03c5\u03b8\u03b5\u03c1\u03af\u03b1 \u03c4\u03bf\u03c5\u03c2, \u03b1\u03bb\u03bb\u03ac \u03b4\u03b9\u03b1\u03c4\u03b7\u03c1\u03bf\u03cd\u03bd \u03b8\u03b5\u03bc\u03b5\u03bb\u03b9\u03ce\u03b4\u03b7 \u03b4\u03b9\u03ba\u03b1\u03b9\u03ce\u03bc\u03b1\u03c4\u03b1 \u03cc\u03c0\u03c9\u03c2 \u03b7 \u03b1\u03be\u03b9\u03bf\u03c0\u03c1\u03ad\u03c0\u03b5\u03b9\u03b1, \u03b7 \u03b9\u03c3\u03cc\u03c4\u03b7\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03b7 \u03b1\u03bd\u03b8\u03c1\u03ce\u03c0\u03b9\u03bd\u03b7 \u03bc\u03b5\u03c4\u03b1\u03c7\u03b5\u03af\u03c1\u03b9\u03c3\u03b7.","content_text101":"\u039f\u03b9 \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf\u03b9 \u03bc\u03c0\u03bf\u03c1\u03bf\u03cd\u03bd \u03bd\u03b1 \u03c5\u03c0\u03bf\u03b2\u03ac\u03bb\u03bf\u03c5\u03bd \u03c0\u03b1\u03c1\u03ac\u03c0\u03bf\u03bd\u03bf \u03b5\u03ac\u03bd \u03c0\u03b1\u03c1\u03b1\u03b2\u03b9\u03b1\u03c3\u03c4\u03bf\u03cd\u03bd \u03c4\u03b1 \u03b4\u03b9\u03ba\u03b1\u03b9\u03ce\u03bc\u03b1\u03c4\u03ac \u03c4\u03bf\u03c5\u03c2.","content_text201_0":"\u039d\u0391\u0399","content_text201_1":"\u03a8\u0395\u03a5\u0394\u0395\u03a3","content_text301":"\u039c\u03c0\u03bf\u03c1\u03bf\u03cd\u03bd \u03bd\u03b1 \u03c5\u03c0\u03bf\u03b2\u03ac\u03bb\u03bf\u03c5\u03bd \u03c0\u03b1\u03c1\u03ac\u03c0\u03bf\u03bd\u03b1 \u03c3\u03c4\u03b9\u03c2 \u03b1\u03c1\u03c7\u03ad\u03c2 \u03c4\u03b7\u03c2 \u03c6\u03c5\u03bb\u03b1\u03ba\u03ae\u03c2 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03c0\u03c1\u03bf\u03c3\u03c6\u03cd\u03b3\u03bf\u03c5\u03bd \u03c3\u03b5 \u03b4\u03b9\u03ba\u03b1\u03c3\u03c4\u03b9\u03ba\u03ac \u03cc\u03c1\u03b3\u03b1\u03bd\u03b1 \u03b5\u03ac\u03bd \u03c7\u03c1\u03b5\u03b9\u03ac\u03b6\u03b5\u03c4\u03b1\u03b9.","content_text102":"\u03a4\u03bf \u03c0\u03c1\u03bf\u03c3\u03c9\u03c0\u03b9\u03ba\u03cc \u03c4\u03b7\u03c2 \u03c6\u03c5\u03bb\u03b1\u03ba\u03ae\u03c2 \u03b4\u03b5\u03bd \u03c5\u03c0\u03bf\u03c7\u03c1\u03b5\u03bf\u03cd\u03c4\u03b1\u03b9 \u03bd\u03b1 \u03b5\u03be\u03b7\u03b3\u03b5\u03af \u03c4\u03bf\u03c5\u03c2 \u03ba\u03b1\u03bd\u03cc\u03bd\u03b5\u03c2 \u03c3\u03c4\u03bf\u03c5\u03c2 \u03ba\u03c1\u03b1\u03c4\u03bf\u03c5\u03bc\u03ad\u03bd\u03bf\u03c5\u03c2.","content_text202_0":"\u039d\u0391\u0399","content_text202_1":"\u03a8\u0395\u03a5\u0394\u0395\u03a3","content_text302":"\u039f\u03b9 \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf\u03b9 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03b5\u03bd\u03b7\u03bc\u03b5\u03c1\u03ce\u03bd\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c3\u03b1\u03c6\u03ce\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03bf\u03c5\u03c2 \u03ba\u03b1\u03bd\u03cc\u03bd\u03b5\u03c2, \u03c4\u03b1 \u03b4\u03b9\u03ba\u03b1\u03b9\u03ce\u03bc\u03b1\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03c4\u03b9\u03c2 \u03b4\u03b9\u03b1\u03b4\u03b9\u03ba\u03b1\u03c3\u03af\u03b5\u03c2 \u03bc\u03b5 \u03c4\u03c1\u03cc\u03c0\u03bf \u03c0\u03bf\u03c5 \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03bf\u03cd\u03bd.","content_text103":"\u0388\u03bd\u03b1\u03c2 \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf\u03c2 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03b6\u03b7\u03c4\u03ae\u03c3\u03b5\u03b9 \u03bc\u03b5\u03c4\u03ac\u03c6\u03c1\u03b1\u03c3\u03b7 \u03b5\u03ac\u03bd \u03b4\u03b5\u03bd \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03b5\u03af \u03c4\u03b7 \u03b3\u03bb\u03ce\u03c3\u03c3\u03b1.","content_text203_0":"\u0391\u039b\u0397\u0398\u0395\u03a3","content_text203_1":"\u03a8\u0395\u03a5\u0394\u0395\u03a3","content_text303":"\u0395\u03ac\u03bd \u03c5\u03c0\u03ac\u03c1\u03c7\u03b5\u03b9 \u03b3\u03bb\u03c9\u03c3\u03c3\u03b9\u03ba\u03cc \u03b5\u03bc\u03c0\u03cc\u03b4\u03b9\u03bf, \u03bf\u03b9 \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf\u03b9 \u03ad\u03c7\u03bf\u03c5\u03bd \u03b4\u03b9\u03ba\u03b1\u03af\u03c9\u03bc\u03b1 \u03b4\u03b9\u03b5\u03c1\u03bc\u03b7\u03bd\u03b5\u03af\u03b1\u03c2 \u03ae \u03bc\u03b5\u03c4\u03ac\u03c6\u03c1\u03b1\u03c3\u03b7\u03c2.","content_text104":"\u039f\u03b9 \u03b8\u03c1\u03b7\u03c3\u03ba\u03b5\u03c5\u03c4\u03b9\u03ba\u03ad\u03c2 \u03c0\u03c1\u03b1\u03ba\u03c4\u03b9\u03ba\u03ad\u03c2 \u03b4\u03b5\u03bd \u03b5\u03c0\u03b9\u03c4\u03c1\u03ad\u03c0\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c3\u03c4\u03b7 \u03c6\u03c5\u03bb\u03b1\u03ba\u03ae.","content_text204_0":"\u0391\u039b\u0397\u0398\u0395\u03a3","content_text204_1":"\u03a8\u0395\u03a5\u0394\u0395\u03a3","content_text304":"\u0388\u03c7\u03bf\u03c5\u03bd \u03b4\u03b9\u03ba\u03b1\u03af\u03c9\u03bc\u03b1 \u03bd\u03b1 \u03b5\u03bd\u03b7\u03bc\u03b5\u03c1\u03ce\u03bd\u03bf\u03bd\u03c4\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03c4\u03b9\u03c2 \u03c0\u03c1\u03bf\u03c3\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bd \u03bc\u03ad\u03c3\u03c9 \u03bd\u03bf\u03bc\u03b9\u03ba\u03ce\u03bd \u03b4\u03b9\u03b1\u03b4\u03b9\u03ba\u03b1\u03c3\u03b9\u03ce\u03bd.","content_text105":"\u039f\u03b9 \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf\u03b9 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03c0\u03ac\u03bd\u03c4\u03b1 \u03bd\u03b1 \u03b1\u03c0\u03bf\u03b4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c0\u03b5\u03b9\u03b8\u03b1\u03c1\u03c7\u03b9\u03ba\u03ad\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03c7\u03c9\u03c1\u03af\u03c2 \u03b4\u03c5\u03bd\u03b1\u03c4\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c0\u03c1\u03bf\u03c3\u03c6\u03c5\u03b3\u03ae\u03c2.","content_text205_0":"\u0391\u039b\u0397\u0398\u0395\u03a3","content_text205_1":"\u03a8\u0395\u03a5\u0394\u0395\u03a3","content_text305":"\u0388\u03c7\u03bf\u03c5\u03bd \u03b4\u03b9\u03ba\u03b1\u03af\u03c9\u03bc\u03b1 \u03bd\u03b1 \u03b5\u03bd\u03b7\u03bc\u03b5\u03c1\u03ce\u03bd\u03bf\u03bd\u03c4\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03c4\u03b9\u03c2 \u03c0\u03c1\u03bf\u03c3\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bd \u03bc\u03ad\u03c3\u03c9 \u03bd\u03bf\u03bc\u03b9\u03ba\u03ce\u03bd \u03b4\u03b9\u03b1\u03b4\u03b9\u03ba\u03b1\u03c3\u03b9\u03ce\u03bd.","content_text106":"\u0397 \u03b5\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03bf\u03b9\u03ba\u03bf\u03b3\u03ad\u03bd\u03b5\u03b9\u03b1 (\u03c4\u03b7\u03bb\u03b5\u03c6\u03c9\u03bd\u03ae\u03bc\u03b1\u03c4\u03b1, \u03b5\u03c0\u03b9\u03c3\u03ba\u03ad\u03c8\u03b5\u03b9\u03c2, \u03b3\u03c1\u03ac\u03bc\u03bc\u03b1\u03c4\u03b1) \u03b5\u03c0\u03b9\u03c4\u03c1\u03ad\u03c0\u03b5\u03c4\u03b1\u03b9.","content_text206_0":"\u0391\u039b\u0397\u0398\u0395\u03a3","content_text206_1":"\u03a8\u0395\u03a5\u0394\u0395\u03a3","content_text306":"\u0397 \u03b4\u03b9\u03b1\u03c4\u03ae\u03c1\u03b7\u03c3\u03b7 \u03b5\u03c0\u03b1\u03c6\u03ae\u03c2 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03bf\u03b9\u03ba\u03bf\u03b3\u03ad\u03bd\u03b5\u03b9\u03b1 \u03ba\u03b1\u03b9 \u03bd\u03bf\u03bc\u03b9\u03ba\u03bf\u03cd\u03c2 \u03c3\u03c5\u03bc\u03b2\u03bf\u03cd\u03bb\u03bf\u03c5\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c3\u03b7\u03bc\u03b1\u03bd\u03c4\u03b9\u03ba\u03cc \u03b4\u03b9\u03ba\u03b1\u03af\u03c9\u03bc\u03b1 \u03ba\u03b1\u03b9 \u03c5\u03c0\u03bf\u03c3\u03c4\u03b7\u03c1\u03af\u03b6\u03b5\u03b9 \u03c4\u03b7\u03bd \u03b5\u03c5\u03b7\u03bc\u03b5\u03c1\u03af\u03b1."}}