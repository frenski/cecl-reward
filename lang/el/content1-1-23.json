{"texts":{"content_text0":"\u03a3\u0397\u039c\u0395\u0399\u039f \u0395\u03a0\u0391\u039d\u0395\u039e\u0395\u03a4\u0391\u03a3\u0397\u03a3","content_text3":"HIV","content_text4":"\u0397\u03c0\u03b1\u03c4\u03af\u03c4\u03b9\u03b4\u03b1 \u0393","content_text5":"\u03a6\u03c5\u03bc\u03b1\u03c4\u03af\u03c9\u03c3\u03b7","content_text6":"\u0394\u03b9\u03b1\u03b2\u03ae\u03c4\u03b7\u03c2","content_text8":"\u0399\u03cc\u03c2 \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03c3\u03b2\u03ac\u03bb\u03bb\u03b5\u03b9 \u03c4\u03bf \u03b1\u03bd\u03bf\u03c3\u03bf\u03c0\u03bf\u03b9\u03b7\u03c4\u03b9\u03ba\u03cc \u03c3\u03cd\u03c3\u03c4\u03b7\u03bc\u03b1","content_text10":"\u039b\u03bf\u03af\u03bc\u03c9\u03be\u03b7 \u03bc\u03ad\u03c3\u03c9 \u03b1\u03af\u03bc\u03b1\u03c4\u03bf\u03c2 \u03c0\u03bf\u03c5 \u03c3\u03c5\u03c7\u03bd\u03ac \u03c3\u03c5\u03bd\u03b4\u03ad\u03b5\u03c4\u03b1\u03b9 \u03bc\u03b5 \u03ba\u03bf\u03b9\u03bd\u03ad\u03c2 \u03c3\u03cd\u03c1\u03b9\u03b3\u03b3\u03b5\u03c2","content_text9":"\u039c\u03b5\u03c4\u03b1\u03b4\u03af\u03b4\u03b5\u03c4\u03b1\u03b9 \u03bc\u03ad\u03c3\u03c9 \u03b1\u03ad\u03c1\u03b1 \u03c3\u03b5 \u03c3\u03c5\u03bd\u03c9\u03c3\u03c4\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf\u03c5\u03c2 \u03c7\u03ce\u03c1\u03bf\u03c5\u03c2","content_text7":"\u039b\u03bf\u03af\u03bc\u03c9\u03be\u03b7 \u03bc\u03ad\u03c3\u03c9 \u03b1\u03af\u03bc\u03b1\u03c4\u03bf\u03c2 \u03c0\u03bf\u03c5 \u03c3\u03c5\u03c7\u03bd\u03ac \u03c3\u03c5\u03bd\u03b4\u03ad\u03b5\u03c4\u03b1\u03b9 \u03bc\u03b5 \u03ba\u03bf\u03b9\u03bd\u03ad\u03c2 \u03c3\u03cd\u03c1\u03b9\u03b3\u03b3\u03b5\u03c2","content_text1":"\u03a3\u0397\u039c\u0395\u0399\u039f \u0395\u039e\u0395\u03a4\u0391\u03a3\u0397\u03a3 #5","content_text2":"\u0391\u03bd\u03c4\u03b9\u03c3\u03c4\u03bf\u03b9\u03c7\u03af\u03c3\u03c4\u03b5 \u03c4\u03b7\u03bd \u03c0\u03ac\u03b8\u03b7\u03c3\u03b7 \u03bc\u03b5 \u03c4\u03b7 \u03c3\u03c9\u03c3\u03c4\u03ae \u03c0\u03b5\u03c1\u03b9\u03b3\u03c1\u03b1\u03c6\u03ae:","content_text300":"\u03c5\u03c0\u03bf\u03b2\u03bf\u03bb\u03ae","content_text200":"\u03a0\u03ae\u03c1\u03b1\u03c4\u03b5 %s \u03b1\u03c0\u03cc %s \u03c3\u03c9\u03c3\u03c4\u03ac"}}