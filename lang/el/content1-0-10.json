{
    "texts": {
        "content_text0": "ΣΗΜΕΙΟ ΕΠΑΝΕΞΕΤΑΣΗΣ ",
        "content_text1": "ΣΗΜΕΙΟ ΕΠΑΝΕΞΕΤΑΣΗΣ #2",
        "content_text400": "Α",
        "content_text401": "Β",
        "content_text402": "Γ",
        "content_text403": "Δ",
        "content_text4": "υποβολή",
        "content_text2": "Τι πρέπει να γίνει πριν εφαρμοστούν πειθαρχικά μέτρα; <br><i>Επιλέξτε τη/τις σωστή/ές απάντηση/εις</i>",
        "content_text100": "Άμεση επιβολή ποινής",
        "content_text101": "Αγνόηση της κατάστασης",
        "content_text102": "Απόπειρα αποκλιμάκωσης μέσω επικοινωνίας",
        "content_text103": "Μεταγωγή όλων των εμπλεκόμενων κρατουμένων"
    }
}