{"texts":{"content_text0":"\u03a3\u0397\u039c\u0395\u0399\u039f \u0395\u03a0\u0391\u039d\u0395\u039e\u0395\u03a4\u0391\u03a3\u0397\u03a3","content_text2":"<b>\u0394\u03b9\u03b1\u03b2\u03ac\u03c3\u03c4\u03b5 \u03c4\u03b7\u03bd \u03b5\u03c1\u03ce\u03c4\u03b7\u03c3\u03b7 \u03ba\u03b1\u03b9 \u03b5\u03c0\u03b9\u03bb\u03ad\u03be\u03c4\u03b5 \u03c4\u03b7\/\u03c4\u03b9\u03c2 \u03c3\u03c9\u03c3\u03c4\u03ae\/\u03ad\u03c2 \u03b1\u03c0\u03ac\u03bd\u03c4\u03b7\u03c3\u03b7\/\u03b5\u03b9\u03c2.<\/b><br><br>\u03a4\u03b9 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03ba\u03ac\u03bd\u03b5\u03b9 \u03c4\u03bf \u03c0\u03c1\u03bf\u03c3\u03c9\u03c0\u03b9\u03ba\u03cc \u03b5\u03ac\u03bd \u03c0\u03b1\u03c1\u03b1\u03c4\u03b7\u03c1\u03ae\u03c3\u03b5\u03b9 \u03c0\u03c1\u03bf\u03b5\u03b9\u03b4\u03bf\u03c0\u03bf\u03b9\u03b7\u03c4\u03b9\u03ba\u03ac \u03c3\u03b7\u03bc\u03ac\u03b4\u03b9\u03b1 \u03c8\u03c5\u03c7\u03b9\u03ba\u03ae\u03c2 \u03b4\u03c5\u03c3\u03c6\u03bf\u03c1\u03af\u03b1\u03c2;","content_text400":"\u0391","content_text401":"\u0392","content_text402":"\u0393","content_text403":"\u0394","content_text4":"\u03c5\u03c0\u03bf\u03b2\u03bf\u03bb\u03ae","content_text1":"\u03a3\u0397\u039c\u0395\u0399\u039f \u0395\u039e\u0395\u03a4\u0391\u03a3\u0397\u03a3 #2","content_text100":"\u039d\u03b1 \u03c4\u03b1 \u03b1\u03b3\u03bd\u03bf\u03ae\u03c3\u03b5\u03b9","content_text101":"\u039d\u03b1 \u03c0\u03b5\u03c1\u03b9\u03bc\u03ad\u03bd\u03b5\u03b9 \u03bd\u03b1 \u03bb\u03c5\u03b8\u03b5\u03af \u03b7 \u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b1\u03c3\u03b7 \u03b1\u03c0\u03cc \u03bc\u03cc\u03bd\u03b7 \u03c4\u03b7\u03c2","content_text102":"\u039d\u03b1 \u03c0\u03b1\u03c1\u03b1\u03c0\u03ad\u03bc\u03c8\u03b5\u03b9 \u03c4\u03bf\u03bd \u03ba\u03c1\u03b1\u03c4\u03bf\u03cd\u03bc\u03b5\u03bd\u03bf \u03c3\u03b5 \u03b5\u03c0\u03b1\u03b3\u03b3\u03b5\u03bb\u03bc\u03b1\u03c4\u03af\u03b5\u03c2 \u03c8\u03c5\u03c7\u03b9\u03ba\u03ae\u03c2 \u03c5\u03b3\u03b5\u03af\u03b1\u03c2","content_text103":"\u039d\u03b1 \u03b5\u03c6\u03b1\u03c1\u03bc\u03cc\u03c3\u03b5\u03b9 \u03ac\u03bc\u03b5\u03c3\u03b1 \u03c0\u03b5\u03b9\u03b8\u03b1\u03c1\u03c7\u03b9\u03ba\u03ac \u03bc\u03ad\u03c4\u03c1\u03b1"}}