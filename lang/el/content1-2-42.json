{
    "texts": {
        "content_text0": "ΣΗΜΕΙΟ ΕΠΑΝΕΞΕΤΑΣΗΣ",
        "content_text1": "ΣΗΜΕΙΟ ΕΠΑΝΕΞΕΤΑΣΗΣ #5",
        "content_text2": "Αντιστοιχίστε την έννοια με τη σωστή περιγραφή:",
        "content_text3": "Προειδοποιητικά σημάδια",
        "content_text4": "Διαδικασία παραπομπής",
        "content_text5": "Υπηρεσίες υποστήριξης",
        "content_text6": "Ασφαλές περιβάλλον",
        "content_text7": "Χαριστική εκχώρηση αντικειμένων ή ασυνήθιστη συμπεριφορά",
        "content_text10": "Έγκαιρη αναγνώριση και δράση",
        "content_text8": "Πρόσβαση σε επαγγελματίες όταν χρειάζεται",
        "content_text9": "Σεβασμός, σαφείς κανόνες, χωρίς εκφοβισμό",
        "content_text300": "υποβολή",
        "content_text200": "Πήρατε %s από %s σωστά"
    }
}